<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="net.talaatharb.gsplat.ui.MainController"
            styleClass="root-pane">

    <!-- Top: Menu Bar + Toolbar -->
    <top>
        <VBox>
            <MenuBar fx:id="menuBar">
                <Menu text="File">
                    <MenuItem text="New Project..." onAction="#onNewProject" accelerator="Shortcut+N"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Settings..." onAction="#onOpenSettings"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#onExit"/>
                </Menu>
                <Menu text="View">
                    <MenuItem text="Viewer" />
                    <MenuItem text="Training" />
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" />
                </Menu>
            </MenuBar>
            <ToolBar fx:id="toolBar" styleClass="main-toolbar">
                <Button text="New Project" onAction="#onNewProject" styleClass="toolbar-btn"/>
                <Separator/>
                <Button text="Settings" onAction="#onOpenSettings" styleClass="toolbar-btn"/>
            </ToolBar>
        </VBox>
    </top>

    <!-- Left: Project Tree -->
    <left>
        <VBox styleClass="project-panel" prefWidth="220">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
            <Label text="Projects" styleClass="panel-title"/>
            <TreeView fx:id="projectTree" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- Center: Tab Pane -->
    <center>
        <TabPane fx:id="centerTabs" tabClosingPolicy="UNAVAILABLE"/>
    </center>

    <!-- Bottom: Log Console -->
    <bottom>
        <VBox styleClass="log-panel" prefHeight="150">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
            <Label text="Log" styleClass="panel-title"/>
            <TextArea fx:id="logConsole" editable="false" wrapText="true"
                      VBox.vgrow="ALWAYS" styleClass="log-console"/>
        </VBox>
    </bottom>
</BorderPane>
